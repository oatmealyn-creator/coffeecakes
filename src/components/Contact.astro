---
import { PHONE, ADDRESS } from '../data/constants';
---

<section id="contact" class="contact-section">
  <div class="contact-container">
    <div class="blackboard">
      <h2>📋 Hours &amp; Details</h2>
      <div class="chalk-text">
        <p><strong>📍 Address:</strong><br />{ADDRESS}</p>
        <p><strong>⏰ Operating Hours:</strong><br />Monday - Sunday: 9:00 AM - 10:00 PM</p>
        <p><strong>📞 Contact Us:</strong><br />{PHONE} (Delivery Available)</p>
        <p class="handwritten" style="color: var(--accent); font-size: 1.5rem; text-align: center; border: none;">&ldquo;Drop by for the cozy vibes, stay for the perfect brew!&rdquo;</p>
      </div>
    </div>
    <div class="map-frame">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3942.75852387234!2d76.9982854!3d8.6043959!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3b05b80f8ff055a9%3A0x1a163ff2100f6796!2sCoffee%20Cakes!5e0!3m2!1sen!2sin!4v1716800000000!5m2!1sen!2sin" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Coffee Cakes location on Google Maps" sandbox="allow-scripts allow-same-origin allow-popups" width="600" height="450"></iframe>
    </div>
  </div>
</section>
